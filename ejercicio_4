-- e=edificio u=unidades x= expensas

select e.nombre, sum(x.monto) as totalimpago
from edificios e
inner join unidades u on e.idedificio = u.idedificio
inner join expensas x on u.idunidad = x.idunidad
where x.estado = 'impago'
group by e.nombre
having sum(x.monto) > 1000000 
and count(u.idunidad) > 5;

select e.nombre, avg(x.monto) as promedio
from edificios e
inner join unidades u on e.idedificio = u.idedificio
inner join expensas x on u.idunidad = x.idunidad
where x.estado = 'pago'
group by e.nombre
having avg(x.monto) >= 20000;

select e.nombre, sum(x.monto) as recaudado
from edificios e
inner join unidades u on e.idedificio = u.idedificio
inner join expensas x on u.idunidad = x.idunidad
where x.estado = 'pago'
group by e.nombre
order by recaudado desc
limit 3;
