create database edificios;
use edificios;

create table edificios (
  idedificio int auto_increment primary key,
  nombre varchar(100),
  direccion varchar(200)
);

create table unidades (
  idunidad int primary key,
  nropiso int,
  idedificio int,
  foreign key (idedificio) references edificios(idedificio)
);

create table expensas (
  idexp int primary key,
  idunidad int,
  monto decimal(10,2),
  estado varchar(10),
  foreign key (idunidad) references unidades(idunidad)
);

