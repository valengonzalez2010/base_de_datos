select artistas.nombre as artista, sum(reproducciones.cant_repro) as total_reproducciones
from artistas
-- INNER JOIN: une las tablas por sus claves relacionadas (artista → álbum → reproducciones)
inner join albumes on artistas.id_art = albumes.id_art
--         tabla1  on tabla2.pkcolumna2          = tabla1.pkcolumna2 
inner join reproducciones on albumes.id_alb = reproducciones.id_alb
-- GROUP BY: agrupa los resultados por artista para aplicar funciones de agregación (SUM, COUNT)
group by artistas.nombre
-- HAVING: filtra los grupos creados por GROUP BY según condiciones agregadas
having count(albumes.id_alb) > 3 
and sum(reproducciones.cant_repro) > 1000000;

select albumes.titulo as album,artistas.nombre as artista,avg(reproducciones.cant_repro) as promedio_reproducciones
from albumes
--         tabla1  on tabla2.pkcolumna2          = tabla1.pkcolumna2 
inner join artistas on albumes.id_art = artistas.id_art
--         tabla1  on tabla2.pkcolumna2          = tabla1.pkcolumna2 

inner join reproducciones on albumes.id_alb = reproducciones.id_alb
	--   tabla1.campo1   , tabla2.campo2
group by albumes.titulo, artistas.nombre
-- luego de filtrar los grupos, hace el promedio de las reproducciones y si supera los 50k te manda aca:
having avg(reproducciones.cant_repro) > 50000;
-- hace la lista de los que cumplen las anteriores condiciones en orden ascendiente.
select artistas.nombre as artista,sum(reproducciones.cant_repro) as total_reproducciones
from artistas
inner join albumes on artistas.id_art = albumes.id_art
inner join reproducciones on albumes.id_alb = reproducciones.id_alb
group by artistas.nombre
order by total_reproducciones asc
limit 1;
