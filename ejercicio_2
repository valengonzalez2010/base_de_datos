create database streaming_musica;
use streaming_musica;

create table artistas(
    id_art int primary key auto_increment not null,
    nombre varchar(100)
);

create table albumes(
    id_alb int primary key auto_increment not null,
    titulo varchar(100),
    id_art int,
    foreign key (id_art) references artistas(id_art)
);

create table reproducciones(
    id_rep int primary key auto_increment not null,
    id_alb int,
    cant_repro int,
    foreign key (id_alb) references albumes(id_alb)
);

