-- c = categorias  p = productos  d = detalleventa

select c.nombrecat as categoria, p.nombre as producto, sum(d.cantidad) as totalvendido
from categorias c
inner join productos p on c.idcat = p.idcat
inner join detalleventa d on p.idprod = d.idprod
group by c.nombrecat, p.nombre
having sum(d.cantidad) > 500
order by totalvendido desc
limit 1;

-- c = categorias  p = productos  d = detalleventa

select c.nombrecat as categoria, avg(p.precio) as preciopromedio, sum(d.cantidad) as vendidos
from categorias c
inner join productos p on c.idcat = p.idcat
inner join detalleventa d on p.idprod = d.idprod
group by c.nombrecat
having avg(p.precio) > 1500 
and sum(d.cantidad) >= 10;


-- c = categorias  p = productos  d = detalleventa cat = categoría 

select c.nombrecat as categoria, sum(d.cantidad * d.preciounit) as recaudacion
from categorias c
inner join productos p on c.idcat = p.idcat
inner join detalleventa d on p.idprod = d.idprod
where p.precio < 100
group by c.nombrecat
having sum(d.cantidad * d.preciounit) < 5000;
