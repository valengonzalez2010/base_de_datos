select nombre as restaurante, sum(cantidad) as pedidos_totales
from restaurantes 
--         tabla1  on tabla2.pkcolumna2          = tabla1.pkcolumna2 
inner join platos  on restaurantes.IDrestaurante = platos.IDrestaurante
--          tabla1 on tabla2.pkcolumna2 = tabla1.pkcolumna2
inner join pedidos on platos.IDplato = pedidos.IDplato
--        nombretabla (de la que quiero que agrupes).campodelatabla ( da a entender: los restaurantes que cumplan la condicion de los inner join, agrupa sus nombres. ) 
group by restaurantes.nombre 
--           nombretabla.IDPK ( da a entender: contame la cantidad de platos en total, que sean mayor a 5)
having count(platos.IDplato) > 5 
--      nombretabla.campo (da a entender: Y suma en base a la cantidad de pedidos, muestra los que superan los 200)
and sum(pedidos.cantidad) > 200;

select nombre as restaurante, avg(pedido.cantidad * pedido.precio) as promedioingreso
from restaurantes 
--         tabla1  on tabla2.pkcolumna2          = tabla1.pkcolumna2 
inner join platos on restaurante.IDrestaurante = platos.IDrestaurante
--         tabla1  on tabla2.pkcolumna2          = tabla1.pkcolumna2
inner join pedidos on platos.IDplato = pedidos.IDplato
-- donde agrupando los inresos de los platos, sea mayor a 1500
where platos.precio > 1500
--        nombretabla (de la que quiero que agrupes).campodelatabla ( da a entender: los restaurantes que cumplan la condicion de los inner join, agrupa sus nombres. ) 
group by restaurantes.nombre;
