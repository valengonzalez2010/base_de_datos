create database controlvuelos;
use controlvuelos;

create table aviones (
    idavion int primary key auto_increment,
    modelo varchar(50) not null,
    capacidad int not null
);

create table pasajeros (
    dnipasajero varchar(15) primary key,
    nombre varchar(100) not null,
    apellido varchar(100) not null
);

create table vuelos (
    idvuelo int primary key auto_increment,
    origen varchar(50) not null,
    destino varchar(50) not null,
    fechahora datetime not null,
    idavion int not null,
    foreign key (idavion) references aviones(idavion)
);

create table pasajerosvuelo (
    idticket int primary key auto_increment,
    idvuelo int not null,
    dnipasajero varchar(15) not null,
    precioticket decimal(10,2) not null,
    foreign key (idvuelo) references vuelos(idvuelo),
    foreign key (dnipasajero) references pasajeros(dnipasajero)
);

