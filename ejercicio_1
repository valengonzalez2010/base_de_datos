– a = avion
v= vuelo
pv= pasajerosvuelo
select a.modelo,  sum(pv.precioticket) as totalrecaudado, count(pv.idticket) as totalpasajeros
from aviones a
join vuelos v on a.idavion = v.idavion
join pasajerosvuelo pv on v.idvuelo = pv.idvuelo
group by a.idavion, a.modelo
having sum(pv.precioticket) > 2000000 
   and count(pv.idticket) > 100;

select 
    v.idvuelo, 
    v.destino,
    avg(pv.precioticket) as promedioticket
from vuelos v
join pasajerosvuelo pv on v.idvuelo = pv.idvuelo
where v.origen = 'ezeiza'
group by v.idvuelo, v.destino
having avg(pv.precioticket) > 500;

select 
    a.modelo, 
    count(v.idvuelo) as cantidadvuelos
from aviones a
join vuelos v on a.idavion = v.idavion
where v.fechahora >= date_sub(curdate(), interval 1 month)
group by a.idavion, a.modelo
having count(v.nrovuelo) > 50;
